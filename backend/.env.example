# =============================================================================
# AI Python Tutor 配置文件模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# =============================================================================

# --- 应用配置 ---
APP_NAME="AI Python Tutor"
APP_ENV=development          # development | testing | staging | production
DEBUG=true                   # 开发模式下更详细的错误信息
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars  # JWT 签名密钥

# --- 服务器配置 ---
HOST=0.0.0.0
PORT=8000

# --- CORS 配置 ---
# 允许访问后端的前端地址，多个用逗号分隔
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# --- 数据库配置 ---
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./ai_tutor.db
# 生产环境使用 PostgreSQL（需要先启动 PostgreSQL 容器）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_tutor

# --- DeepSeek AI 配置 ---
DEEPSEEK_API_KEY=sk-your-api-key-here       # DeepSeek API Key（从 platform.deepseek.com 获取）
DEEPSEEK_BASE_URL=https://api.deepseek.com   # DeepSeek API 地址
DEEPSEEK_MODEL=deepseek-chat                 # 默认模型（deepseek-chat 或 deepseek-reasoner）
DEEPSEEK_FALLBACK_MODEL=                     # 备用模型（可选）

# --- AI 参数默认值 ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60                               # API 调用超时（秒）

# --- Redis 配置（可选，MVP 阶段可用内存替代） ---
# REDIS_URL=redis://localhost:6379/0

# --- Embedding 配置（RAG 语义检索） ---
# 阿里云百炼 DashScope API Key（从 bailian.console.aliyun.com 获取）
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
EMBEDDING_MODEL=text-embedding-v3           # text-embedding-v1 | v2 | v3

# --- 日志配置 ---
LOG_LEVEL=DEBUG                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                           # console（彩色输出）| json（生产环境用）
